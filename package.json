{
  "name": "vite-react-svg",
  "version": "0.0.12",
  "description": "Vite plugin to transform SVGs into React components",
  "author": "thednp",
  "license": "MIT",
  "homepage": "https://github.com/thednp/vite-react-svg#readme",
  "keywords": [
    "vite",
    "plugin",
    "svg",
    "react"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/thednp/vite-react-svg"
  },
  "bugs": {
    "url": "https://github.com/thednp/vite-react-svg/issues"
  },
  "main": "src/index.mjs",
  "module": "src/index.mjs",
  "types": "src/types.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "import": "./src/index.mjs",
      "types": "./src/types.d.ts"
    }
  },
  "files": [
    "src/index.mjs",
    "src/htmlToReact.mjs",
    "src/global.d.ts",
    "src/types.d.ts",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "vite serve demo --config vite.config.ts",
    "bench": "node --experimental-transform-types demo/benchmark.ts",
    "test": "vitest --config vitest.config.ts",
    "test-ui": "vitest --config vitest.config.ts --ui=true",
    "prepublishOnly": "pnpm update --latest && pnpm lint && pnpm format",
    "format": "deno fmt src/*.mjs src/*.ts demo/*.tsx demo/*.ts",
    "lint": "pnpm lint:ts",
    "lint:ts": "deno lint src/*.mjs",
    "fix:ts": "deno lint src/*.mjs --fix",
    "check:ts": "tsc -noEmit"
  },
  "dependencies": {
    "@rollup/pluginutils": "^5.3.0",
    "@thednp/domparser": "^0.1.9",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "vite": "^5.0.0 || ^6.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/browser": "^4.1.2",
    "@vitest/coverage-istanbul": "^4.1.2",
    "@vitest/ui": "^4.1.2",
    "typescript": "^6.0.2",
    "vite": "^8.0.3",
    "vite-plugin-svgr": "^4.5.0",
    "vitest": "^4.1.2"
  },
  "packageManager": "pnpm@10.33.0"
}